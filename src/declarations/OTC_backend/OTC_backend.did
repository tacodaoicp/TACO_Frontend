                                             ICRC3;
                                           }) -> (ActionResult);
 };
type TradePrivate2 = 
 record {
   Fee: nat;
   OCname: text;
   RevokeFee: nat;
   SellerPrincipal: text;
   accesscode: text;
   allOrNothing: bool;
   amount_init: nat;
   amount_sell: nat;
   filledInit: nat;
   filledSell: nat;
   initPrincipal: text;
   init_paid: nat;
   init_paid2: nat;
   seller_paid: nat;
   seller_paid2: nat;
   strictlyOTC: bool;
   time: int;
   token_init_identifier: text;
   token_sell_identifier: text;
   trade_done: nat;
   trade_number: nat;
 };
type TradePrivate = 
 record {
   Fee: nat;
   OCname: text;
   RevokeFee: nat;
   SellerPrincipal: text;
   allOrNothing: bool;
   amount_init: nat;
   amount_sell: nat;
   filledInit: nat;
   filledSell: nat;
   initPrincipal: text;
   init_paid: nat;
   init_paid2: nat;
   seller_paid: nat;
   seller_paid2: nat;
   strictlyOTC: bool;
   time: int;
   token_init_identifier: text;
   token_sell_identifier: text;
   trade_done: nat;
   trade_number: nat;
 };
type TradePosition = 
 record {
   Fee: nat;
   OCname: text;
   allOrNothing: bool;
   amount_init: nat;
   amount_sell: nat;
   filledInit: nat;
   filledSell: nat;
   initPrincipal: text;
   strictlyOTC: bool;
   time: int;
   token_init_identifier: text;
   token_sell_identifier: text;
   trade_done: nat;
   trade_number: nat;
 };
type TradeData = 
 record {
   ICPPrice: nat;
   amountBuy: nat;
   amountSell: nat;
   block: nat64;
   decimals: nat;
   identifier: text;
   transferFee: nat;
 };
type TokenInfo = 
 record {
   address: text;
   asset_type: variant {
                 ICP;
                 ICRC12;
                 ICRC3;
               };
   decimals: nat;
   minimum_amount: nat;
   name: text;
   symbol: text;
   transfer_fee: nat;
 };
type TimeFrame = 
 variant {
   day;
   fivemin;
   fourHours;
   hour;
   week;
 };
type Time = int;
type SwapResult = 
 variant {
   Err: ExchangeError;
   Ok: SwapOk;
 };
type SwapRecord = 
 record {
   amountIn: nat;
   amountOut: nat;
   fee: nat;
   route: vec text;
   swapId: nat;
   swapType: variant {
               direct;
               limit;
               multihop;
               otc;
             };
   timestamp: int;
   tokenIn: text;
   tokenOut: text;
 };
type SwapOk = 
 record {
   amountIn: nat;
   amountOut: nat;
   fee: nat;
   firstHopOrderbookMatch: bool;
   hops: nat;
   lastHopAMMOnly: bool;
   route: vec text;
   swapId: nat;
   tokenIn: text;
   tokenOut: text;
 };
type SwapHop = 
 record {
   tokenIn: text;
   tokenOut: text;
 };
type SplitLeg = 
 record {
   amountIn: nat;
   minLegOut: nat;
   route: vec SwapHop;
 };
type RevokeResult = 
 variant {
   Err: ExchangeError;
   Ok: RevokeOk;
 };
type RevokeOk = 
 record {
   accessCode: text;
   refunds: vec record {
                  amount: nat;
                  token: text;
                };
   revokeType: variant {
                 DAO;
                 Initiator;
                 Seller;
               };
 };
type RemoveLiquidityResult = 
 variant {
   Err: ExchangeError;
   Ok: RemoveLiquidityOk;
 };
type RemoveLiquidityOk = 
 record {
   amount0: nat;
   amount1: nat;
   fees0: nat;
   fees1: nat;
   liquidityBurned: nat;
 };
type RemoveConcentratedResult = 
 variant {
   Err: ExchangeError;
   Ok: RemoveConcentratedOk;
 };
type RemoveConcentratedOk = 
 record {
   amount0: nat;
   amount1: nat;
   fees0: nat;
   fees1: nat;
   liquidityRemaining: nat;
   liquidityRemoved: nat;
 };
type RecoveryResult = 
 record {
   block: nat;
   error: text;
   identifier: text;
   success: bool;
 };
type RecoveryInput = 
 record {
   block: nat;
   identifier: text;
   tType: variant {
            ICP;
            ICRC12;
            ICRC3;
          };
 };
type RecalibratedPosition = 
 record {
   accesscode: text;
   amountInit: nat;
   amountSell: nat;
   fee: nat;
   poolId: record {
             text;
             text;
           };
   revokeFee: nat;
 };
type Ratio = 
 variant {
   Max;
   Value: nat;
   Zero;
 };
type ProcessedTrade = 
 record {
   amountBought: nat;
   amountSold: nat;
   identifier: text;
 };
type PositionData = 
 record {
   ICPprice: record {
               nat;
               nat;
             };
   accesscode: text;
   decimals: record {
               nat;
               nat;
             };
 };
type PoolQuery = 
 record {
   backwardCursor: opt Ratio;
   forwardCursor: opt Ratio;
   pool: record {
           text;
           text;
         };
 };
type PoolLiquidity = 
 record {
   backward:
    vec
     record {
       Ratio;
       vec
        record {
          Fee: nat;
          OCname: text;
          RevokeFee: nat;
          accesscode: text;
          allOrNothing: bool;
          amount_init: nat;
          amount_sell: nat;
          initPrincipal: text;
          strictlyOTC: bool;
          time: int;
          token_init_identifier: text;
          token_sell_identifier: text;
        };
     };
   forward:
    vec
     record {
       Ratio;
       vec
        record {
          Fee: nat;
          OCname: text;
          RevokeFee: nat;
          accesscode: text;
          allOrNothing: bool;
          amount_init: nat;
          amount_sell: nat;
          initPrincipal: text;
          strictlyOTC: bool;
          time: int;
          token_init_identifier: text;
          token_sell_identifier: text;
        };
     };
 };
type PoolDailySnapshot = 
 record {
   activeLiquidity: nat;
   reserve0: nat;
   reserve1: nat;
   timestamp: int;
   totalLiquidity: nat;
   volume: nat;
 };
type OrderResult = 
 variant {
   Err: ExchangeError;
   Ok: OrderOk;
 };
type OrderOk = 
 record {
   accessCode: text;
   amountIn: nat;
   buyAmountReceived: nat;
   filled: nat;
   isPublic: bool;
   remaining: nat;
   swapId: opt nat;
   tokenIn: text;
   tokenOut: text;
 };
type LogLevel = 
 variant {
   ERROR;
   INFO;
   WARN;
 };
type LogEntry = 
 record {
   component: text;
   context: text;
   level: LogLevel;
   message: text;
   timestamp: int;
 };
type LPFeeClaimEntry = 
 record {
   dust0ToDAO: nat;
   dust1ToDAO: nat;
   fees0: nat;
   fees1: nat;
   positionId: nat;
   ratioLower: nat;
   ratioUpper: nat;
   source: variant {
             v2;
             v3;
           };
   token0: text;
   token1: text;
   transferred0: nat;
   transferred1: nat;
 };
type KlineData = 
 record {
   close: float64;
   high: float64;
   low: float64;
   open: float64;
   timestamp: int;
   volume: nat;
 };
type HopDetail = 
 record {
   amountIn: nat;
   amountOut: nat;
   fee: nat;
   priceImpact: float64;
   tokenIn: text;
   tokenOut: text;
 };
type ForeignPoolsResponse = 
 record {
   nextPoolCursor: opt PoolQuery;
   pools: vec ForeignPoolLiquidity;
 };
type ForeignPoolLiquidity = 
 record {
   backwardCursor: Ratio;
   forwardCursor: Ratio;
   liquidity: PoolLiquidity;
   pool: record {
           text;
           text;
         };
 };
type ExchangeError = 
 variant {
   Banned;
   ExchangeFrozen;
   InsufficientFunds: text;
   InvalidInput: text;
   NotAuthorized;
   OrderNotFound: text;
   PoolNotFound: text;
   RouteFailed: record {
                  hop: nat;
                  reason: text;
                };
   SlippageExceeded: record {
                       expected: nat;
                       got: nat;
                     };
   SystemError: text;
   TokenNotAccepted: text;
   TokenPaused: text;
   TransferFailed: text;
 };
type DetailedLiquidityPosition = 
 record {
   fee0: nat;
   fee1: nat;
   liquidity: nat;
   positionId: opt nat;
   positionType: variant {
                   concentrated;
                   fullRange;
                 };
   ratioLower: opt nat;
   ratioUpper: opt nat;
   shareOfPool: float64;
   token0: text;
   token0Amount: nat;
   token1: text;
   token1Amount: nat;
 };
type ConcentratedPositionDetailed = 
 record {
   fee0: nat;
   fee1: nat;
   lastFeeGrowth0: nat;
   lastFeeGrowth1: nat;
   lastUpdateTime: int;
   liquidity: nat;
   positionId: nat;
   ratioLower: nat;
   ratioUpper: nat;
   token0: text;
   token0Amount: nat;
   token1: text;
   token1Amount: nat;
 };
type ClaimFeesResult = 
 variant {
   Err: ExchangeError;
   Ok: ClaimFeesOk;
 };
type ClaimFeesOk = 
 record {
   dust0ToDAO: nat;
   dust1ToDAO: nat;
   fees0: nat;
   fees1: nat;
   transferred0: nat;
   transferred1: nat;
 };
type ClaimAllLPFeesResult = 
 variant {
   Err: ExchangeError;
   Ok: ClaimAllLPFeesOk;
 };
type ClaimAllLPFeesOk = 
 record {
   consolidationSavings: vec record {
                               text;
                               nat;
                             };
   entries: vec LPFeeClaimEntry;
   positionsClaimed: nat;
   positionsScanned: nat;
   totalsTransferredByToken: vec record {
                                   text;
                                   nat;
                                 };
 };
type BatchProcessResult = 
 record {
   accesscodes:
    vec
     record {
       accesscode: text;
       amountInit: nat;
       amountSell: nat;
       fee: nat;
       poolId: record {
                 text;
                 text;
               };
       revokeFee: nat;
     };
   execMessage: text;
   processedTrades: vec ProcessedTrade;
 };
type AddLiquidityResult = 
 variant {
   Err: ExchangeError;
   Ok: AddLiquidityOk;
 };
type AddLiquidityOk = 
 record {
   amount0Used: nat;
   amount1Used: nat;
   liquidityMinted: nat;
   refund0: nat;
   refund1: nat;
   token0: text;
   token1: text;
 };
type AddConcentratedResult = 
 variant {
   Err: ExchangeError;
   Ok: AddConcentratedOk;
 };
type AddConcentratedOk = 
 record {
   amount0Used: nat;
   amount1Used: nat;
   liquidity: nat;
   positionId: nat;
   priceLower: nat;
   priceUpper: nat;
   refund0: nat;
   refund1: nat;
   token0: text;
   token1: text;
 };
type ActionResult = 
 variant {
   Err: ExchangeError;
   Ok: text;
 };
service : () -> create_trading_canister
