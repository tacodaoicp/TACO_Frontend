type pool = 
 record {
   amm_reserve0: vec nat;
   amm_reserve1: vec nat;
   asset_decimals: vec record {
                         nat8;
                         nat8;
                       };
   asset_minimum_amount: vec record {
                               nat;
                               nat;
                             };
   asset_names: vec record {
                      text;
                      text;
                    };
   asset_symbols: vec record {
                        text;
                        text;
                      };
   asset_transferfees: vec record {
                             nat;
                             nat;
                           };
   last_traded_price: vec float64;
   pool_canister: vec record {
                        text;
                        text;
                      };
   price_day_before: vec float64;
   volume_24h: vec nat;
 };
type create_trading_canister = 
 service {
   ChangeReferralFees: (newFeePercentage: nat) -> ();
   ChangeRevokefees: (ok: nat) -> () oneway;
   ChangeTradingfees: (ok: nat) -> () oneway;
   FinishSell: (Block: nat64, accesscode: text, amountSelling: nat) ->
    (ActionResult);
   FinishSellBatch: (Block: nat64, accesscode: vec text,
    amount_Sell_by_Reactor: vec nat, token_sell_identifier: text,
    token_init_identifier: text) -> (ActionResult);
   FinishSellBatchDAO: (trades: vec TradeData, createOrdersIfNotDone: 
    bool, special: vec nat) -> (opt BatchProcessResult);
   FixStuckTX: (accesscode: text) -> (ActionResult);
   Freeze: () -> ();
   addAcceptedToken: (action: variant {
                                Add;
                                Opposite;
                                Remove;
                              }, added2: text, minimum: nat, tType:
    variant {
      ICP;
      ICRC12;
      ICRC3;
    }) -> (ActionResult);
   addConcentratedLiquidity: (token0i: text, token1i: text, amount0i: 
    nat, amount1i: nat, priceLower: nat, priceUpper: nat, block0i: nat,
    block1i: nat) -> (AddConcentratedResult);
   addFeeCollector: (p: principal) -> (ActionResult);
   addLiquidity: (token0i: text, token1i: text, amount0i: nat, amount1i: 
    nat, block0i: nat, block1i: nat, isInitial: opt bool) ->
    (AddLiquidityResult);
   addLiquidityDAO: (token0i: text, token1i: text, amount0i: nat, amount1i:
    nat, block0i: nat, block1i: nat, isInitial: opt bool) ->
    (AddLiquidityResult);
   addPosition: (Block: nat, amount_sell: nat, amount_init: nat,
    token_sell_identifier: text, token_init_identifier: text, pub: bool,
    excludeDAO: bool, OC: opt text, referrer: text, allOrNothing: bool,
    strictlyOTC: bool) -> (OrderResult);
   addTimer: () -> ();
   adminAnalyzeRouteEfficiency: (token: text, sampleSize: nat, depth: 
    nat) ->
    (vec
      record {
        efficiency: int;
        efficiencyBps: int;
        hopDetails: vec HopDetail;
        outputAmount: nat;
        route: vec SwapHop;
      }) query;
   adminDeleteKlinesBefore: (cutoffNs: int, maxDeletesPerBucket: nat) ->
    (text);
   adminDrainTestModeExchange: (target: principal) -> (text);
   adminDrainTestModeStatus: () -> (text) query;
   adminExecuteRouteStrategy: (amount: nat, route: vec SwapHop, minOutput:
    nat, Block: nat) -> (SwapResult);
   adminFindOptimalArb: (token: text, minSample: nat, maxSample: nat, depth:
    nat, probes: nat, tolerancePct: nat) ->
    (opt
      record {
        amount: nat;
        efficiency: int;
        efficiencyBps: int;
        hopDetails: vec HopDetail;
        outputAmount: nat;
        probesRun: nat;
        route: vec SwapHop;
      }) query;
   adminFlashArb: (notional: nat, route: vec SwapHop, minProfit: nat) ->
    (variant {
       Err: text;
       Ok:
        record {
          capitalSource: variant {
                           lent;
                           phantom;
                         };
          grossProfit: nat;
          hops: nat;
          inputTfees: nat;
          netProfit: nat;
          notional: nat;
          realized: nat;
          swapId: nat;
          tradingFee: nat;
          transferFee: nat;
        };
     });
   adminRepairLastTradedPriceAndKlines: (affectedPoolIndexes: vec nat,
    alsoRepairVolume24h: bool) -> (text);
   batchAdjustLiquidity: (adjustments:
    vec
     record {
       action: variant {Remove: record {liquidityAmount: nat;};};
       token0: text;
       token1: text;
     }) ->
    (vec record {
           result: text;
           success: bool;
           token0: text;
           token1: text;
         });
   batchClaimAllFees: () ->
    (vec
      record {
        fees0: nat;
        fees1: nat;
        token0: text;
        token1: text;
        transferred0: nat;
        transferred1: nat;
      });
   canTradeTokens: (tokenIn: text, tokenOut: text) -> (bool) query;
   changeOwner2: (pri: principal) -> ();
   changeOwner3: (pri: principal) -> ();
   checkDiffs: (returnFees: bool, alwaysShow: bool) ->
    (opt
      record {
        bool;
        vec record {
              int;
              text;
            };
        vec
         vec
          record {
            accessCode: text;
            identifier: text;
            poolCanister: record {
                            text;
                            text;
                          };
          };
      });
   checkFeesReferrer: () -> (vec record {
                                   text;
                                   nat;
                                 }) query;
   claimAllLPFees: () -> (ClaimAllLPFeesResult);
   claimConcentratedFees: (positionId: nat) -> (ClaimFeesResult);
   claimFeesReferrer: () -> (vec record {
                                   text;
                                   nat;
                                 });
   claimLPFees: (token0i: text, token1i: text) -> (ClaimFeesResult);
   cleanTokenIds: () -> (ActionResult);
   clearAllBans: () -> ();
   clearStuckLocks: (accesscode: opt text, blocksDoneKey: opt text) -> (bool);
   clearTokenArchiveOffset: (token: text) -> (bool);
   collectFees: () -> (ActionResult);
   debugV3Ticks: (token0: text, token1: text) ->
    (record {
       activeLiquidity: nat;
       currentSqrtRatio: nat;
       reserveRatio: nat;
       reserveSqrtRatio: nat;
       ticks: vec record {
                    liquidityGross: nat;
                    liquidityNet: int;
                    tick: nat;
                  };
     }) query;
   exchangeInfo: () -> (opt pool) query;
   getAMMPoolInfo: (token0: text, token1: text) ->
    (opt
      record {
        price0: float64;
        price1: float64;
        reserve0: nat;
        reserve1: nat;
        token0: text;
        token1: text;
      }) query;
   getAcceptedTokens: () -> (opt vec text) query;
   getAcceptedTokensInfo: () -> (opt vec TokenInfo) query;
   getAllAMMPools: () ->
    (vec
      record {
        price0: float64;
        price1: float64;
        reserve0: nat;
        reserve1: nat;
        token0: text;
        token1: text;
        totalLiquidity: nat;
      }) query;
   getAllPoolStats: () ->
    (vec
      record {
        activeLiquidity: nat;
