           vec TradePrivate;
         }) query;
   getAllTradesPublic: () -> (opt record {
                                    vec text;
                                    vec TradePrivate;
                                  }) query;
   getAllowedCanisters: () -> (vec text) query;
   getCurrentLiquidity: (token1: text, token2: text, direction:
    variant {
      backward;
      forward;
    }, limit: nat, cursor: opt Ratio) ->
    (record {
       liquidity:
        vec
         record {
           Ratio;
           vec
            record {
              Fee: nat;
              OCname: text;
              RevokeFee: nat;
              accesscode: text;
              allOrNothing: bool;
              amount_init: nat;
              amount_sell: nat;
