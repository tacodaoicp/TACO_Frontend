              token_init_identifier: text;
              token_sell_identifier: text;
            };
         };
       nextCursor: Ratio;
     }) query;
   getCurrentLiquidityForeignPools: (limit: nat, poolQuery:
    opt vec PoolQuery, onlySpecifiedPools: bool) ->
    (ForeignPoolsResponse) query;
   getDAOLPPerformance: () ->
    (vec
      record {
        currentValue0: nat;
        currentValue1: nat;
        poolVolume24h: nat;
        shareOfPool: float64;
        token0: text;
        token1: text;
        totalFeesEarned0: nat;
        totalFeesEarned1: nat;
      }) query;
   getDAOLiquiditySnapshot: () ->
    (record {
       pools:
        vec
         record {
           price0: float64;
           price1: float64;
           reserve0: nat;
           reserve1: nat;
           token0: text;
           token1: text;
           totalLiquidity: nat;
         };
       positions:
        vec
         record {
           fee0: nat;
           fee1: nat;
           liquidity: nat;
           shareOfPool: float64;
           token0: text;
           token0Amount: nat;
           token1: text;
           token1Amount: nat;
         };
     }) query;
   getDriftOpTracker: () -> (vec record {
                                   text;
                                   int;
                                 }) query;
   getExpectedMultiHopAmount: (tokenIn: text, tokenOut: text, amountIn:
    nat) ->
    (record {
       bestRoute: vec SwapHop;
       expectedAmountOut: nat;
       hopDetails: vec HopDetail;
       hops: nat;
       priceImpact: float64;
       routeTokens: vec text;
       totalFee: nat;
     }) query;
   getExpectedReceiveAmount: (tokenSell: text, tokenBuy: text, amountSell:
    nat) ->
    (record {
       canFulfillFully: bool;
       expectedBuyAmount: nat;
       fee: nat;
       hopDetails: vec HopDetail;
       potentialOrderDetails: opt record {
                                    amount_init: nat;
                                    amount_sell: nat;
                                  };
       priceImpact: float64;
       routeDescription: text;
     }) query;
   getExpectedReceiveAmountBatch: (requests:
    vec record {
          amountSell: nat;
          tokenBuy: text;
          tokenSell: text;
        }) ->
    (vec
      record {
        canFulfillFully: bool;
        expectedBuyAmount: nat;
        fee: nat;
        hopDetails: vec HopDetail;
        potentialOrderDetails:
         opt record {
               amount_init: nat;
               amount_sell: nat;
             };
        priceImpact: float64;
        routeDescription: text;
      }) query;
   getExpectedReceiveAmountBatchMulti: (requests:
    vec record {
          amountSell: nat;
          tokenBuy: text;
          tokenSell: text;
        }, maxRoutesPerRequest: nat) ->
    (vec
      record {
        routes:
         vec
          record {
            canFulfillFully: bool;
            expectedBuyAmount: nat;
            fee: nat;
            hopDetails: vec HopDetail;
            potentialOrderDetails:
             opt record {
                   amount_init: nat;
                   amount_sell: nat;
                 };
            priceImpact: float64;
            routeDescription: text;
            routeTokens: vec text;
          };}) query;
   getFeeCollectors: () -> (vec principal) query;
   getKlineData: (token1: text, token2: text, timeFrame: TimeFrame,
    initialGet: bool) -> (vec KlineData) query;
   getKlineDataRange: (token1: text, token2: text, timeFrame: TimeFrame,
    before: opt int, limit: nat) -> (vec KlineData) query;
   getLogging: (functionType: variant {
                                FinishSellBatchDAO;
                                addAcceptedToken;
                              }, getLastXEntries: nat) ->
    (vec record {
           nat;
           text;
         }) query;
   getLogs: (count: nat) -> (vec LogEntry) query;
   getOrderbookCombined: (token0: text, token1: text, numLevels: nat,
    stepBasisPoints: nat) ->
    (record {
       ammMidPrice: float64;
       ammReserve0: nat;
       ammReserve1: nat;
       asks:
        vec
         record {
           ammAmount: nat;
           limitAmount: nat;
           limitOrders: nat;
           price: float64;
         };
       bids:
        vec
         record {
           ammAmount: nat;
           limitAmount: nat;
           limitOrders: nat;
           price: float64;
         };
       spread: float64;
     }) query;
   getPausedTokens: () -> (opt vec text) query;
   getPoolHistory: (token1: text, token2: text, limit: nat) ->
    (vec
      record {
        Time;
        vec
         record {
           accesscode: text;
           allOrNothing: bool;
           amount_init: nat;
           amount_sell: nat;
           init_principal: text;
           sell_principal: text;
           strictlyOTC: bool;
           token_init_identifier: text;
         };
      }) query;
   getPoolRanges: (token0: text, token1: text) ->
    (vec
      record {
        liquidity: nat;
        ratioLower: nat;
        ratioUpper: nat;
        token0Locked: nat;
        token1Locked: nat;
      }) query;
   getPoolStats: (token0: text, token1: text) ->
    (opt
      record {
        activeLiquidity: nat;
        decimals0: nat;
        decimals1: nat;
        feeRateBps: nat;
        feesLifetimeToken0: nat;
        feesLifetimeToken1: nat;
        history: vec PoolDailySnapshot;
        lpFeeSharePct: nat;
        price0: float64;
        price1: float64;
        priceChange24hPct: float64;
        reserve0: nat;
        reserve1: nat;
        symbol0: text;
        symbol1: text;
        token0: text;
        token1: text;
        totalLiquidity: nat;
        volume24h: nat;
        volume7d: nat;
      }) query;
   getPrivateTrade: (pass: text) -> (opt TradePosition) query;
   getTokenArchiveOffset: (token: text) -> (opt nat) query;
   getTokenUSDPrices: (ICPpriceUSD: float64, ckUSDCpriceUSD: float64) ->
    (opt
      record {
        data:
         vec
          record {
            text;
            record {
              address: text;
              priceUSD: float64;
              timeLastValidUpdate: int;
            };
          };
        error: bool;
      }) query;
   getUserConcentratedPositions: () ->
    (vec ConcentratedPositionDetailed) query;
   getUserLiquidityDetailed: () -> (vec DetailedLiquidityPosition) query;
   getUserPreviousTrades: (token1: text, token2: text) ->
    (vec
      record {
        accesscode: text;
        allOrNothing: bool;
        amount_init: nat;
        amount_sell: nat;
        init_principal: text;
        sell_principal: text;
        strictlyOTC: bool;
        timestamp: int;
        token_init_identifier: text;
      }) query;
   getUserReferralInfo: () ->
    (record {
       hasReferrer: bool;
       isFirstTrade: bool;
       referralEarnings: vec record {
                               text;
                               nat;
                             };
       referrer: opt text;
     }) query;
   getUserSwapHistory: (limit: nat) -> (vec SwapRecord) query;
   getUserTradeHistory: (limit: nat) ->
    (vec
      record {
        accesscode: text;
        amount_init: nat;
        amount_sell: nat;
        counterparty: text;
        timestamp: int;
        token_init_identifier: text;
        token_sell_identifier: text;
      }) query;
   getUserTrades: () -> (vec TradePrivate2) query;
   get_cycles: () -> (nat) query;
   get_token_trends_7d: (tokens: vec principal) ->
    (variant {
       err: text;
       ok:
        vec
         record {
           change_pct_24h: float64;
           change_pct_7d: float64;
           points: vec float64;
           price_now: float64;
           token: principal;
         };
     }) query;
   hmFee: () -> (nat) query;
   hmRefFee: () -> (nat) query;
   hmRevokeFee: () -> (nat) query;
   isExchangeFrozen: () -> (bool) query;
   p2a: () -> (text) query;
   p2acannister: () -> (text) query;
   p2athird: (p: text) -> (text);
   parameterManagement: (parameters:
    record {
      addAllowedCanisters: opt vec text;
      addToAllTimeBan: opt vec text;
      changeAllowedCalls: opt nat;
      changeallowedSilentWarnings: opt nat;
      daoTreasuryPrincipalsText: opt vec text;
      deleteAllowedCanisters: opt vec text;
      deleteFromAllTimeBan: opt vec text;
      deleteFromDayBan: opt vec text;
      treasury_principal: opt text;
    }) -> ();
   pauseToken: (token: text) -> ();
   recalibrateDAOpositions: (positions: vec PositionData) ->
    (vec RecalibratedPosition);
   recoverBatch: (recoveries: vec RecoveryInput) -> (vec RecoveryResult);
   recoverWronglysent: (identifier: text, Block: nat, tType:
    variant {
      ICP;
      ICRC12;
      ICRC3;
    }) -> (bool);
   refundStuckFunds: () -> (text);
   removeConcentratedLiquidity: (token0i: text, token1i: text, positionId:
    nat, liquidityAmount: nat) -> (RemoveConcentratedResult);
   removeFeeCollector: () -> (ActionResult);
   removeLiquidity: (token0i: text, token1i: text, liquidityAmount: nat) ->
    (RemoveLiquidityResult);
   resetAllState: () -> (text);
   resetDriftOpTracker: () -> ();
   retrieveFundsDao: (trades: vec record {
                                    text;
                                    nat64;
                                  }) -> ();
   returncontractprincipal: () -> (text) query;
   revokeTrade: (accesscode: text, revokeType:
    variant {
      DAO: vec text;
      Initiator;
      Seller;
    }) -> (RevokeResult);
   sendDAOInfo: () ->
    (vec
      record {
        text;
        record {
          Decimals: nat;
          Name: text;
          Symbol: text;
          TransferFee: nat;
        };
      }) query;
   setMinimumAmount: (token: text, newMinimum: nat) -> (ActionResult);
   setTest: (a: bool) -> ();
   swapMultiHop: (tokenIn: text, tokenOut: text, amountIn: nat, route:
    vec SwapHop, minAmountOut: nat, Block: nat) -> (SwapResult);
   swapSplitRoutes: (tokenIn: text, tokenOut: text, splits: vec SplitLeg,
    minAmountOut: nat, Block: nat) -> (SwapResult);
   treasurySwap: (tokenIn: text, tokenOut: text, amountIn: nat, minAmountOut:
    nat, block: nat) -> (SwapResult);
   updateTokenType: (token: text, newType: variant {
                                             ICP;
